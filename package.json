{
  "name": "brigada-ouro",
  "version": "3.0.0",
  "description": "Sistema de Registro de Ocorrências de Incêndio Florestal",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:local": "cd app && node server.js",
    "dev:cf": "wrangler pages dev app/public --d1=DB",
    "deploy": "wrangler pages deploy app/public",
    "db:init": "wrangler d1 execute brigada-ouro --remote --file=./schema.sql",
    "db:create": "wrangler d1 create brigada-ouro",
    "build:worker": "node worker-build.js"
  },
  "devDependencies": {
    "@turf/turf": "^7.1.0",
    "bcryptjs": "^2.4.3",
    "esbuild": "^0.24.0",
    "fflate": "^0.8.2",
    "jose": "^5.9.6",
    "pdf-lib": "^1.17.1",
    "xlsx": "^0.18.5"
  }
}
